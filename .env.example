# CLICK INDIA CAPITAL - MASTER ENVIRONMENT MANIFEST
# Use this as a template for .env.development, .env.staging, and .env.production

# 1. CORE BACKEND (Supabase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 2. ECOSYSTEM DOMAINS
VITE_WEB_URL=https://www.clickindiacapital.in
VITE_CRM_URL=https://admin.clickindiacapital.in
VITE_API_URL=https://your-project.supabase.co/functions/v1

# 3. PAYMENT GATEWAY (Razorpay / Cashfree)
PAYMENT_GATEWAY_KEY=your-key
PAYMENT_GATEWAY_SECRET=your-secret

# 4. COMMUNICATION (WhatsApp / Email)
WHATSAPP_API_TOKEN=your-token
SENDGRID_API_KEY=your-key

# 5. MONITORING (Sentry / PostHog)
VITE_SENTRY_DSN=your-dsn
VITE_POSTHOG_KEY=your-key

# 6. MOBILE (Expo)
EXPO_PROJECT_ID=your-project-id
